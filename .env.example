# MySQL Configuration for gomigrate
# These environment variables can be used to override configs in example.yaml

# Source Database Settings
GOMIGRATE_SOURCE_TYPE=mysql
GOMIGRATE_SOURCE_HOST=localhost
GOMIGRATE_SOURCE_PORT=3306
GOMIGRATE_SOURCE_DATABASE=myapp_db
GOMIGRATE_SOURCE_USER=migrator
GOMIGRATE_SOURCE_PASSWORD=password123

# Target Database Settings (if MySQL is the target)
GOMIGRATE_TARGET_TYPE=mysql
GOMIGRATE_TARGET_HOST=prod-mysql.internal
GOMIGRATE_TARGET_PORT=3306
GOMIGRATE_TARGET_DATABASE=myapp_db
GOMIGRATE_TARGET_USER=migrator
GOMIGRATE_TARGET_PASSWORD=prod_password

# Adapter Specific Settings
# Enable LOAD DATA LOCAL INFILE support (requires server-side config)
GOMIGRATE_MYSQL_ALLOW_LOCAL_INFILE=true
