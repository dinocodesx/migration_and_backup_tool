# ==============================================================================
# Infrastructure (Docker Compose)
# ==============================================================================

# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=appdb

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=appdb
MYSQL_USER=user
MYSQL_PASSWORD=password

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# Cassandra
CASSANDRA_CLUSTER_NAME=TestCluster
CASSANDRA_KEYSPACE=app_keyspace

# MinIO / S3 (Local Storage Mock)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# Iceberg Catalog Infrastructure
CATALOG_WAREHOUSE=s3a://warehouse/
CATALOG_IO__IMPL=org.apache.iceberg.aws.s3.S3FileIO
CATALOG_S3_ENDPOINT=http://minio:9000
CATALOG_S3_ACCESS_KEY_ID=admin
CATALOG_S3_SECRET_ACCESS_KEY=password

# ==============================================================================
# Cloud Provider Credentials
# ==============================================================================

# AWS / S3 (Standard SDK vars)
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1

# Google Cloud Storage (Standard SDK vars)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ==============================================================================
# Security & Secret Management
# ==============================================================================

# Secret Provider: env | vault | aws_secrets_manager | file
GOMIGRATE_SECRETS_PROVIDER=env

# HashiCorp Vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=root

# ==============================================================================
# Application Configuration (gomigrate)
# Prefix: GOMIGRATE_ (e.g., GOMIGRATE_SOURCE_TYPE maps to Config.Source.Type)
# ==============================================================================

# Operation mode: migrate | backup | restore | verify | status | schema
GOMIGRATE_OPERATION=backup

# --- Source Database ---
GOMIGRATE_SOURCE_TYPE=postgres
GOMIGRATE_SOURCE_HOST=localhost
# GOMIGRATE_SOURCE_HOSTS=localhost1,localhost2 # For Cassandra
GOMIGRATE_SOURCE_PORT=5432
GOMIGRATE_SOURCE_USER=user
GOMIGRATE_SOURCE_PASSWORD=password
GOMIGRATE_SOURCE_DATABASE=testdb
# GOMIGRATE_SOURCE_KEYSPACE=mykeyspace       # For Cassandra
# GOMIGRATE_SOURCE_PATH=./local.db           # For SQLite
GOMIGRATE_SOURCE_TABLES=demo_users

# --- Target Database ---
GOMIGRATE_TARGET_TYPE=postgres
GOMIGRATE_TARGET_HOST=localhost
# GOMIGRATE_TARGET_HOSTS=localhost1,localhost2 # For Cassandra
GOMIGRATE_TARGET_PORT=5432
GOMIGRATE_TARGET_USER=user
GOMIGRATE_TARGET_PASSWORD=password
GOMIGRATE_TARGET_DATABASE=targetdb
# GOMIGRATE_TARGET_KEYSPACE=mykeyspace       # For Cassandra
# GOMIGRATE_TARGET_PATH=./target.db          # For SQLite

# --- Concurrency & Performance ---
GOMIGRATE_CONCURRENCY_NUM_READERS=4
GOMIGRATE_CONCURRENCY_NUM_TRANSFORMERS=4
GOMIGRATE_CONCURRENCY_NUM_WRITERS=4
GOMIGRATE_CONCURRENCY_BATCH_SIZE=1000
GOMIGRATE_CONCURRENCY_BATCH_TIMEOUT=1s
GOMIGRATE_CONCURRENCY_RATE_LIMIT_RPS=0

# --- Backup Configuration ---
GOMIGRATE_BACKUP_FORMAT=parquet
GOMIGRATE_BACKUP_COMPRESSION=snappy
GOMIGRATE_BACKUP_CHUNK_SIZE_MB=512
GOMIGRATE_BACKUP_STORAGE_TYPE=local
GOMIGRATE_BACKUP_STORAGE_BUCKET=my-backups
GOMIGRATE_BACKUP_STORAGE_PREFIX=backups/
GOMIGRATE_BACKUP_STORAGE_REGION=us-east-1

# --- Checkpoint Configuration ---
GOMIGRATE_CHECKPOINT_PATH=checkpoint.bolt
GOMIGRATE_CHECKPOINT_FLUSH_EVERY_N_BATCHES=10

# --- Telemetry & Observability ---
GOMIGRATE_TELEMETRY_LOG_LEVEL=info
GOMIGRATE_TELEMETRY_LOG_FORMAT=text
GOMIGRATE_TELEMETRY_METRICS_ADDR=:9090
GOMIGRATE_TELEMETRY_TRACING_ENDPOINT=http://localhost:14268/api/traces

# ==============================================================================
# Helper Scripts
# ==============================================================================

# Database URL for demo seeding (demo/seed/main.go)
DATABASE_URL=postgres://user:password@localhost:5432/testdb?sslmode=disable
